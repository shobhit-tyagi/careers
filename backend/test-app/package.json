{
  "name": "fan-rewards-api",
  "version": "1.0.0",
  "description": "Belong FanRewards API - Backend Technical Assessment",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/start.ts",
    "build": "tsc",
    "start": "node dist/start.js",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/data-source.ts",
    "seed": "ts-node src/seed.ts",
    "test": "jest --runInBand --passWithNoTests",
    "test:coverage": "jest --runInBand --passWithNoTests --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.x",
    "@fastify/swagger-ui": "^4.x",
    "@sinclair/typebox": "^0.32.0",
    "amqplib": "0.10.4",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.x",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/amqplib": "0.10.5",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
